# Copy to .env and adjust. Consumed by docker-compose and the app.

# Port the server listens on (host side).
HTTP_PORT=8090

# API-Football (api-sports.io) free-tier key. Live result auto-sync is
# disabled until this is set; the app still runs on the openfootball seed
# and manual admin overrides without it.
API_FOOTBALL_KEY=

# Initial PocketBase superuser, created on first boot if set.
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=
