# Copy to .env and adjust. Consumed by docker-compose and the app.

# Port the server listens on (host side).
HTTP_PORT=8090

# Live results source.
#   - Default (auto): use API-Football only if its key can reach WC2026 (a
#     PAID plan — the free tier excludes season 2026), otherwise pull the
#     free community openfootball JSON. Manual admin override always works.
#   - Force with RESULTS_SOURCE = apifootball | openfootball | auto
API_FOOTBALL_KEY=
RESULTS_SOURCE=auto

# Initial PocketBase superuser, created on first boot if set.
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=
