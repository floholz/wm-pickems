# Copy to .env (or export these) before running the bot.

# Base URL of the wm-pickems deployment the bot plays on.
WMP_BASE_URL=http://127.0.0.1:8090

# The bot account's credentials. Create the user in the PocketBase admin and set
# role=bot / botKind to match BOT_KIND, then add it to your leagues (or set
# BOT_LEAGUE_CODE).
BOT_EMAIL=
BOT_PASSWORD=

# Which prediction strategy: algo (default), claude, or openrouter.
#   algo       — deterministic rating model, no API key needed
#   claude     — native Anthropic API (needs ANTHROPIC_API_KEY below)
#   openrouter — any provider via OpenRouter's one-key gateway (needs
#                OPENROUTER_API_KEY + OPENROUTER_MODEL below). Use this to run
#                GPT/Gemini/etc. bots without juggling per-vendor keys.
BOT_KIND=algo

# Anthropic API key — required only for BOT_KIND=claude.
ANTHROPIC_API_KEY=

# Model id (claude only). Defaults to the flagship; override to trade cost for capability. [claude-haiku-4-5; claude-sonnet-4-6; claude-opus-4-8]
CLAUDE_MODEL=claude-opus-4-8

# OpenRouter API key — required only for BOT_KIND=openrouter. One key + one
# prepaid balance fronts every provider, so you don't manage keys per vendor.
OPENROUTER_API_KEY=

# OpenRouter model id — required for BOT_KIND=openrouter (no default; you pick the
# provider). Tier-1 models honor strict structured outputs out of the box:
#   anthropic/claude-opus-4-8   openai/gpt-5.1   google/gemini-2.5-pro
# The spottier ones go through the JSON-mode fallback automatically:
#   deepseek/deepseek-chat   x-ai/grok-4   moonshotai/kimi-k2
# (Confirm exact slugs on https://openrouter.ai/models — preview/free ids drift,
# and the model must be allowed on your key + data-policy settings.)
OPENROUTER_MODEL=

# Optional: invite code of a league to auto-join on startup.
BOT_LEAGUE_CODE=

# Log format: text (default, human-readable for local dev) or json
# (structured, for log shippers like Grafana Alloy/Loki). All logs go to stdout.
LOG_FORMAT=text

# Ask the model for a one-line rationale per prediction and persist it to the
# tip/forecast records (claude only; costs extra output tokens). Truthy:
# 1/true/yes/on. Default off.
BOT_RATIONALE=
