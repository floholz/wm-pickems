# Copy to .env (or export these) before running the bot.

# Base URL of the wm-pickems deployment the bot plays on.
WMP_BASE_URL=http://127.0.0.1:8090

# The bot account's credentials. Create the user in the PocketBase admin and set
# role=bot / botKind to match BOT_KIND, then add it to your leagues (or set
# BOT_LEAGUE_CODE).
BOT_EMAIL=
BOT_PASSWORD=

# Which prediction strategy: algo (default) or claude.
#   algo   — deterministic rating model, no API key needed
#   claude — calls the Anthropic API (needs ANTHROPIC_API_KEY below)
BOT_KIND=algo

# Anthropic API key — required only for BOT_KIND=claude.
ANTHROPIC_API_KEY=

# Model id (claude only). Defaults to the flagship; override to trade cost for capability.
CLAUDE_MODEL=claude-opus-4-8

# Optional: invite code of a league to auto-join on startup.
BOT_LEAGUE_CODE=

# Log format: text (default, human-readable for local dev) or json
# (structured, for log shippers like Grafana Alloy/Loki). All logs go to stdout.
LOG_FORMAT=text

# Ask the model for a one-line rationale per prediction and log it (claude only;
# costs extra output tokens). Truthy: 1/true/yes/on. Default off.
BOT_RATIONALE=
